# StockLens environment overrides (all optional).
#
# This file is intentionally near-empty: StockLens has NO secrets, NO credentials,
# and makes NO network calls. Copy to `.env` only if you want to override the
# defaults below; otherwise everything resolves from config/rules.toml.

# Path to the seeded DuckDB database (default: ./stocklens.duckdb).
STOCKLENS_DB=./stocklens.duckdb

# Directory for generated outputs: Parquet extract + aging report (default: ./out).
STOCKLENS_OUT=./out

# Optional path to an alternate rules file (default: ./config/rules.toml).
# STOCKLENS_CONFIG=./config/rules.toml
